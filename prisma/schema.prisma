generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  country   String
  industry  String
  interests String[]
  orders    Order[]
}

model Listing {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  category    String
  createdAt   DateTime @default(now())
  imageUrl    String
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  status    String
  updatedAt DateTime @updatedAt
}
